# Stealth Accumulation Scanner - Environment Variables
# Copy this file to .env and fill in your values

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_CHANNEL_ID=your_channel_chat_id_here

# LLM API Keys (for AI-powered analysis with automatic failover)
# The system will automatically switch providers if one runs out of free chats
# Provider failover order: Ollama (local) -> MiniMax (free tier) -> Gemini -> Anthropic -> OpenAI

# Free local LLM (no API key needed - install from https://ollama.ai)
# Just set ollama_url in config.yaml if using a remote Ollama server

# MiniMax - Free tier available (recommended for failover)
# Get API key: https://platform.minimax.io
MINIMAX_API_KEY=

# Google Gemini - Has free tier
# Get API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude - Has free credits
# Get API key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI GPT - Usually paid
# Get API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: Override alert threshold (default: 60)
# TELEGRAM_ALERT_THRESHOLD=60

# Optional: Override scan interval in minutes (default: 15)
# SCAN_INTERVAL_MINUTES=15
